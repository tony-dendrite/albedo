# Local Postgres for Docker Compose. Use non-default values in your real .env.
ALBEDO_POSTGRES_USER=replace_with_non_default_user
ALBEDO_POSTGRES_PASSWORD=replace_with_non_default_password
ALBEDO_POSTGRES_DB=replace_with_non_default_db
ALBEDO_POSTGRES_HOST=127.0.0.1
ALBEDO_POSTGRES_HOST_PORT=65432

# Chain reader.
CHAIN_NETUID=97
CHAIN_NETWORK=finney
CHAIN_POLL_INTERVAL_S=12
# chain_reader eval filter: only commits at/after this block are eval candidates. 0/unset = no filter.
CHAIN_START_BLOCK=0
# chain_guard backfill: on startup, seed the used_hotkeys ledger with every hotkey that committed
# at/before this block (those hotkeys are blocked from eval). 0/unset = backfill disabled.
IGNORE_COMMITS_TO_BLOCK=8377407

ALBEDO_EVAL_DATABASE_URL=postgresql://replace_with_non_default_user:replace_with_non_default_password@127.0.0.1:65432/replace_with_non_default_db
ALBEDO_EVAL_WORKER_ID=eval-dispatcher-local
ALBEDO_EVAL_REMOTE_AUTH_TOKEN=replace-with-remote-auth-token
ALBEDO_EVAL_DATASET_VERSION=AlienKevin/SWE-ZERO-12M-trajectories
ALBEDO_EVAL_DATASET_MANIFEST_URI=s3://albedo-artifacts/datasets/swe-zero/manifest.json
# sha256 of the LIVE manifest on templar (swe-zero+mini-coder-v1); the old 982a92bd... pin
# was stale drift - datasets.py verifies at download and fails loudly on mismatch.
ALBEDO_EVAL_DATASET_MANIFEST_HASH=980d50ad40e0b5863a4e624b9e313441bda38626fbba089efb95cbec8aa1a9f4
# Optional local manifest path for dispatcher-side deterministic sample IDs.
# S3 manifest fetching is not implemented yet.
ALBEDO_EVAL_DATASET_MANIFEST_PATH=
ALBEDO_EVAL_SAMPLE_COUNT=128
ALBEDO_EVAL_MAX_TURNS_PER_SAMPLE=10
ALBEDO_EVAL_SAMPLING_ALGO=swe-zero-multi-source-sample-v1
ALBEDO_EVAL_JUDGE_CONFIG_HASH=sha256:replace-with-real-hash
ALBEDO_EVAL_ARTIFACT_BUCKET=albedo-artifacts
ALBEDO_EVAL_ARTIFACT_PREFIX=s3://albedo-artifacts
ALBEDO_EVAL_LEASE_SECONDS=1800

ALBEDO_REMOTE_EVAL_API_PORT=8090

# Hippius validation and artifact storage.
ALBEDO_OPENSEARCH_URL=
ALBEDO_OPENSEARCH_USER=
ALBEDO_OPENSEARCH_PASSWORD=
ALBEDO_OPENSEARCH_INDEX=
ALBEDO_MODEL_CACHE_DIR=/root/miners_models
ALBEDO_S3_BUCKET=
ALBEDO_S3_ENDPOINT=
ALBEDO_S3_ACCESS_KEY=
ALBEDO_S3_SECRET_KEY=
HIPPIUS_HUB_TOKEN=


ALBEDO_MONITOR_INTERVAL_S=2
ALBEDO_DASHBOARD_NETUID=97
ALBEDO_DASHBOARD_ARTIFACT_BASE_URL=https://s3.hippius.com

# Sanity pre-eval - GPU worker (stateless; deploy on any GPU box; no DB/dataset/OR key here).
SANITY_REMOTE_AUTH_TOKEN=replace-with-shared-bearer-token
SANITY_REMOTE_HOST_ID=sanity-remote-1
SANITY_REMOTE_API_PORT=9100
SANITY_REMOTE_VLLM_PORT=9101
SANITY_REMOTE_GPU_IDS=0
SANITY_REMOTE_GPU_UTIL=0.5
SANITY_REMOTE_VLLM_DTYPE=bfloat16
SANITY_REMOTE_VLLM_STARTUP_S=180
SANITY_REMOTE_DOWNLOAD_TIMEOUT_S=300
SANITY_REMOTE_MODEL_CACHE_DIR=/root/miners_models
SANITY_REMOTE_MAX_MODEL_LEN=0  # 0 = canonical (262144)
SANITY_REMOTE_MOCK_AUTO_RESULT=false

# Sanity pre-eval - dispatcher (stable host; DB defaults to the ALBEDO_POSTGRES_* DSN above).
SANITY_DISPATCH_WORKER_ID=sanity-dispatcher
SANITY_DISPATCH_REMOTE_AUTH_TOKEN=replace-with-shared-bearer-token
SANITY_DISPATCH_CONSENSUS=false
SANITY_DISPATCH_DATASET_MANIFEST_PATH=
SANITY_DISPATCH_DATASET_MANIFEST_HASH=980d50ad40e0b5863a4e624b9e313441bda38626fbba089efb95cbec8aa1a9f4
SANITY_DISPATCH_DATASET_ROOT=
SANITY_DISPATCH_SAMPLE_COUNT=3
SANITY_DISPATCH_MAX_TURNS_PER_SAMPLE=10
SANITY_DISPATCH_GEN_MAX_TOKENS=32768
SANITY_DISPATCH_LEASE_SECONDS=600
SANITY_DISPATCH_MIN_FREE_GPUS=1

# Sanity pre-eval - SSH tunnel (stable opens -L to the GPU worker; re-point per GPU box).
ALBEDO_SANITY_GPU_HOST_USER=root
ALBEDO_SANITY_GPU_HOST_SSH_HOST=replace-with-gpu-host
ALBEDO_SANITY_GPU_HOST_SSH_PORT=
ALBEDO_SANITY_TUNNEL_LOCAL_PORT=19100

# Local judge API settings. This service runs on the backend host and calls OpenRouter.
ALBEDO_JUDGE_OPENROUTER_API_KEY=replace-with-openrouter-api-key
ALBEDO_JUDGE_OPENROUTER_BASE_URL=https://openrouter.ai/api
ALBEDO_JUDGE_REQUEST_TIMEOUT_SECONDS=90
ALBEDO_JUDGE_RETRY_COUNT=2
ALBEDO_JUDGE_RETRY_BACKOFF_SECONDS=1.5
ALBEDO_JUDGE_TEMPERATURE=0.0
ALBEDO_JUDGE_MAX_TOKENS=768
ALBEDO_JUDGE_MAX_CONCURRENCY_PER_MODEL=8
ALBEDO_JUDGE_MIN_VALID_FRACTION=0.5

# Backend-initiated WebSocket bridge for GPU scoring callbacks.
ALBEDO_SCORE_BRIDGE_REMOTE_WS_URL=ws://127.0.0.1:18090/score-bridge
ALBEDO_SCORE_BRIDGE_REMOTE_AUTH_TOKEN=replace-with-remote-auth-token
ALBEDO_SCORE_BRIDGE_REQUEST_TIMEOUT_SECONDS=300
ALBEDO_SCORE_BRIDGE_RECONNECT_MIN_SECONDS=1
ALBEDO_SCORE_BRIDGE_RECONNECT_MAX_SECONDS=30
ALBEDO_SCORE_BRIDGE_PING_INTERVAL_SECONDS=20
ALBEDO_SCORE_BRIDGE_PING_TIMEOUT_SECONDS=20
ALBEDO_SCORE_BRIDGE_WEBSOCKET_MAX_SIZE_BYTES=2147483648

# Remote eval API settings.
ALBEDO_REMOTE_AUTH_TOKEN=replace-with-remote-auth-token
ALBEDO_REMOTE_HOST_ID=replace-with-remote-host-id
ALBEDO_REMOTE_GPU_COUNT=8
ALBEDO_REMOTE_ACCELERATOR_TYPE=B200
ALBEDO_REMOTE_MOCK_AUTO_VERDICT=false
ALBEDO_REMOTE_MOCK_CHALLENGER_WON=false
ALBEDO_REMOTE_DATASET_ROOT=
ALBEDO_REMOTE_PREVIOUS_KING_GPU_IDS=0,1,2,3
ALBEDO_REMOTE_CHALLENGER_GPU_IDS=4,5,6,7
ALBEDO_REMOTE_MAX_NEW_TOKENS=1024
ALBEDO_REMOTE_ENFORCE_EAGER=false
ALBEDO_REMOTE_USE_CANONICAL_MODEL_CONFIG=true
ALBEDO_REMOTE_RESOLVE_MODEL_ARTIFACTS=true
ALBEDO_REMOTE_MODEL_CACHE_DIR=/tmp/albedo-remote-models
ALBEDO_REMOTE_ARTIFACT_SPOOL_DIR=/tmp/albedo-remote-artifacts
ALBEDO_REMOTE_SCORING_TIMEOUT_SECONDS=300
ALBEDO_REMOTE_SCORING_MIN_VALID_FRACTION=0.5
ALBEDO_REMOTE_UPLOAD_ARTIFACTS=true
ALBEDO_REMOTE_CLEANUP_LOCAL_ARTIFACTS=false
ALBEDO_REMOTE_S3_ENDPOINT_URL=
ALBEDO_REMOTE_S3_REGION=
ALBEDO_REMOTE_S3_ACCESS_KEY_ID=
ALBEDO_REMOTE_S3_SECRET_ACCESS_KEY=
ALBEDO_REMOTE_S3_SESSION_TOKEN=

# Backend-initiated SSH tunnel settings. Fill these in locally; do not commit real host/user secrets.
ALBEDO_GPU_HOST_USER=replace-with-ssh-user
ALBEDO_GPU_HOST_SSH_HOST=replace-with-ssh-host
ALBEDO_TUNNEL_BACKEND_LOCAL_GPU_PORT=18090

# Weight setter. Fill in the validator wallet locally before starting PM2.
ALBEDO_WEIGHT_COLDKEY=
ALBEDO_WEIGHT_HOTKEY=
# Only set this if your validator wallet is not under ~/.bittensor/wallets.
ALBEDO_WEIGHT_WALLET_PATH=
ALBEDO_WEIGHT_NETWORK=finney
ALBEDO_WEIGHT_NETUID=97
ALBEDO_WEIGHT_SET_RATE_BLOCKS=100
ALBEDO_WEIGHT_POLL_SECONDS=12
ALBEDO_WEIGHT_BURN_UID=0






# --- albedo-simple additions ---
# Dispatcher-side base URLs for the GPU workers (through the SSH tunnels).
ALBEDO_EVAL_REMOTE_BASE_URL=http://127.0.0.1:18090
SANITY_DISPATCH_REMOTE_BASE_URL=http://127.0.0.1:19100
# Offline test guards - set all three (plus ALBEDO_WEIGHT_MOCK) when testing the flow.
CHAIN_MOCK=false
ALBEDO_MONITOR_MOCK=false

# --- Optional tunables (defaults shown; uncomment to override) ---
# Slack alerting (empty = alerts off; judge/remote legacy names also accepted).
ALBEDO_SLACK_ERROR_WEBHOOK_URL=
#ALBEDO_SLACK_ERROR_ENV=
#ALBEDO_SLACK_ERROR_USERNAME=Albedo Eval Alerts
#ALBEDO_SLACK_ERROR_DEDUPE_SECONDS=300
#ALBEDO_SLACK_ERROR_TIMEOUT_SECONDS=10
# Validation worker.
HIPPIUS_VALIDATION_MOCK=false
#ALBEDO_SIM_THRESHOLD=0.95
#ALBEDO_KNN_CANDIDATES=20
#ALBEDO_MAX_KNN_DIM=16000
#ALBEDO_HV_MAX_ATTEMPTS=5
#ALBEDO_HV_LEASE_SECONDS=600
#ALBEDO_ARCH_SPEC=            # path override; default = packaged architecture_spec.json
