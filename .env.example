#ALBEDO_EVAL_REMOTE_EVENT_TIMEOUT_SECONDS=30
#ALBEDO_EVAL_MAX_RETRY_COUNT=3
#ALBEDO_EVAL_JUDGE_COUNT=3
# Sanity gate.
#SANITY_DISPATCH_MAX_RETRY_COUNT=5
#SANITY_JUDGE_MODELS=          # comma list; default = the eval judge panel
#SANITY_INJECTION_RECHECK_TEMPERATURE=0.2
# Reign / weights workers.
ALBEDO_WEIGHT_MOCK=false
#ALBEDO_WEIGHT_WORKER_ID=weight-setter
#ALBEDO_SET_REIGN_WORKER_ID=set-reign-worker
#ALBEDO_SET_REIGN_POLL_SECONDS=5
#ALBEDO_SET_REIGN_LEASE_SECONDS=   # default: ALBEDO_EVAL_LEASE_SECONDS
# Dashboard publisher.
#ALBEDO_DASHBOARD_DATA_DIR=website/data
#ALBEDO_DASHBOARD_HISTORY_LIMIT=200
#ALBEDO_DASHBOARD_MODEL_FILTER=qwen3.6-35b

# Binary yes/no judging tunables (upstream 3127360 defaults).
#ALBEDO_JUDGE_EVALUATOR_MODEL=z-ai/glm-5.2
#ALBEDO_JUDGE_NUM_QUESTIONS=50
#ALBEDO_JUDGE_QUESTION_MAX_TOKENS=16000
