# GPU test profile: REAL sanity + eval workers on the two test GPUs, but the chain,
# weight setting, and dashboards stay hard-offline. Copy to .env on the test CPU host,
# fill the <required> values, then run scripts/deploy.sh backend + deploy.sh gpu.
#
# Test submissions enter via scripts/ops.py inject-submission (chain ingest is off),
# or by pointing model_uri at a real Hippius repo you uploaded.

# --- HARD OFFLINE GUARDS - do not change in a test env ---
CHAIN_MOCK=true
ALBEDO_WEIGHT_MOCK=true
ALBEDO_MONITOR_MOCK=true
# Keep ALBEDO_S3_* EMPTY: no fault/corpus/dashboard writes leave the machine.
ALBEDO_S3_BUCKET=
ALBEDO_S3_ENDPOINT=
ALBEDO_S3_ACCESS_KEY=
ALBEDO_S3_SECRET_KEY=
ALBEDO_REMOTE_UPLOAD_ARTIFACTS=false
ALBEDO_SLACK_ERROR_WEBHOOK_URL=

# --- Real pieces under test ---
# Workers run real vLLM; all worker mock flags off.
SANITY_REMOTE_MOCK_AUTO_RESULT=false
ALBEDO_REMOTE_MOCK_AUTO_VERDICT=false
# Validation: mock by default (needs OpenSearch to run real - see below).
HIPPIUS_VALIDATION_MOCK=true
#   To exercise real validation instead:
#   docker run -d -p 9200:9200 -e discovery.type=single-node -e DISABLE_SECURITY_PLUGIN=true opensearchproject/opensearch:2
#   then set HIPPIUS_VALIDATION_MOCK=false and ALBEDO_OPENSEARCH_URL=http://127.0.0.1:9200
ALBEDO_OPENSEARCH_URL=
ALBEDO_OPENSEARCH_USER=
ALBEDO_OPENSEARCH_PASSWORD=

# Postgres (local docker compose).
ALBEDO_POSTGRES_USER=albedo_test
ALBEDO_POSTGRES_PASSWORD=<required>
ALBEDO_POSTGRES_DB=albedo_gpu_test
ALBEDO_POSTGRES_HOST=127.0.0.1
ALBEDO_POSTGRES_HOST_PORT=65432

# Model + dataset downloads are ANONYMOUS (public repos); no Hippius/HF tokens needed.
HIPPIUS_HUB_TOKEN=

# Judges - REAL (the sanity gate and duel scoring are part of what a GPU test verifies).
ALBEDO_JUDGE_OPENROUTER_API_KEY=<required>

# Chain identity (used for netuid defaults even with ingest off).
CHAIN_NETUID=97
CHAIN_NETWORK=finney

# --- CPU <-> GPU wiring (fill per test box) ---
ALBEDO_GPU_HOST_USER=root
ALBEDO_GPU_HOST_SSH_HOST=<required-eval-gpu-host>
ALBEDO_TUNNEL_BACKEND_LOCAL_GPU_PORT=18090
ALBEDO_SANITY_GPU_HOST_USER=root
ALBEDO_SANITY_GPU_HOST_SSH_HOST=<required-sanity-gpu-host>
ALBEDO_SANITY_TUNNEL_LOCAL_PORT=19100
ALBEDO_EVAL_REMOTE_BASE_URL=http://127.0.0.1:18090
SANITY_DISPATCH_REMOTE_BASE_URL=http://127.0.0.1:19100
ALBEDO_SCORE_BRIDGE_REMOTE_WS_URL=ws://127.0.0.1:18090/score-bridge

# Bearer tokens (generate fresh per test env).
ALBEDO_EVAL_REMOTE_AUTH_TOKEN=<required>
ALBEDO_REMOTE_AUTH_TOKEN=<required-same-as-above>
ALBEDO_SCORE_BRIDGE_REMOTE_AUTH_TOKEN=<required-same-as-above>
SANITY_REMOTE_AUTH_TOKEN=<required>
SANITY_DISPATCH_REMOTE_AUTH_TOKEN=<required-same-as-sanity>

# --- Eval GPU worker (8-GPU box) ---
ALBEDO_REMOTE_HOST_ID=gpu-test-eval-1
ALBEDO_REMOTE_EVAL_API_PORT=8090
ALBEDO_REMOTE_GPU_COUNT=8
ALBEDO_REMOTE_PREVIOUS_KING_GPU_IDS=0,1,2,3
ALBEDO_REMOTE_CHALLENGER_GPU_IDS=4,5,6,7
ALBEDO_REMOTE_DATASET_ROOT=/root/albedo-datasets
ALBEDO_REMOTE_MODEL_CACHE_DIR=/root/albedo-remote-models

# --- Sanity GPU worker (1-GPU box) ---
SANITY_REMOTE_HOST_ID=gpu-test-sanity-1
SANITY_REMOTE_API_PORT=9100
SANITY_REMOTE_GPU_IDS=0
SANITY_REMOTE_GPU_UTIL=0.9
SANITY_REMOTE_MAX_MODEL_LEN=0  # 0 = canonical (262144)
SANITY_REMOTE_MODEL_CACHE_DIR=/root/miners_models

# --- Dataset pins (same as prod; used for deterministic sampling) ---
ALBEDO_EVAL_DATASET_VERSION=AlienKevin/SWE-ZERO-12M-trajectories
ALBEDO_EVAL_DATASET_MANIFEST_URI=s3://albedo-artifacts/datasets/swe-zero/manifest.json
ALBEDO_EVAL_DATASET_MANIFEST_HASH=980d50ad40e0b5863a4e624b9e313441bda38626fbba089efb95cbec8aa1a9f4
# Small duel for a first bring-up; prod uses 128.
ALBEDO_EVAL_SAMPLE_COUNT=8
ALBEDO_EVAL_JUDGE_CONFIG_HASH=sha256:gpu-test
SANITY_DISPATCH_DATASET_ROOT=/root/albedo-datasets
SANITY_DISPATCH_DATASET_MANIFEST_PATH=/root/albedo-datasets/manifest.json
SANITY_DISPATCH_DATASET_MANIFEST_HASH=980d50ad40e0b5863a4e624b9e313441bda38626fbba089efb95cbec8aa1a9f4
